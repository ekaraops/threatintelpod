{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0"
  xmlns:atom="http://www.w3.org/2005/Atom"
  xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ .Site.Title | plainify | htmlEscape }}</title>
    <link>{{ .Site.BaseURL }}episodes/</link>
    <description>{{ .Site.Params.description | plainify | htmlEscape }}</description>
    <language>{{ .Site.LanguageCode }}</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Site.BaseURL }}episodes/index.xml" rel="self" type="application/rss+xml"/>
    <image>
      <url>{{ .Site.BaseURL }}images/logo.svg</url>
      <title>{{ .Site.Title | plainify | htmlEscape }}</title>
      <link>{{ .Site.BaseURL }}</link>
    </image>
    {{- range (where .Site.RegularPages "Section" "episodes").ByDate.Reverse }}
    <item>
      <title>{{ .Title | plainify | htmlEscape }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      <description>{{ with .Params.description }}{{ . | plainify | htmlEscape }}{{ else }}AI-generated summary from {{ $.Params.channel | plainify | htmlEscape }}{{ end }}{{ with .Params.youtube_url }} | Original: {{ . }}{{ end }}</description>
      {{- with .Params.channel }}
      <category>{{ . | plainify | htmlEscape }}</category>
      {{- end }}
      {{- with .Params.category }}
      <category>{{ . | htmlEscape }}</category>
      {{- end }}
      {{- with .Params.youtube_url }}
      <comments>{{ . }}</comments>
      <media:content url="{{ . }}" medium="video"/>
      {{- end }}
      {{- with .Params.thumbnail }}
      <media:thumbnail url="{{ . }}"/>
      {{- end }}
    </item>
    {{- end }}
  </channel>
</rss>
